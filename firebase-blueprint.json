{
  "entities": {
    "Profile": {
      "title": "User Profile",
      "description": "Basic user information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "language": { "type": "string", "enum": ["kn", "en"] },
        "onboardingComplete": { "type": "boolean" },
        "profileSetupComplete": { "type": "boolean" },
        "healthcareProvider": { "type": "string" },
        "contactNumber": { "type": "string" },
        "emergencyContact": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "language", "onboardingComplete", "profileSetupComplete"]
    },
    "KickSession": {
      "title": "Kick Session",
      "description": "Records a fetal movement tracking session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "count": { "type": "integer" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      },
      "required": ["id", "userId", "count", "startTime"]
    },
    "NutritionLog": {
      "title": "Daily Nutrition Log",
      "description": "Daily checklist of consumed food categories.",
      "type": "object",
      "properties": {
        "ragi": { "type": "boolean" },
        "greens": { "type": "boolean" },
        "pulses": { "type": "boolean" },
        "dairy": { "type": "boolean" },
        "fruits": { "type": "boolean" }
      }
    },
    "Appointment": {
      "title": "Medical Appointment",
      "description": "Scheduled pregnancy check-up or scan.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "location": { "type": "string" },
        "reminders": { "type": "boolean" },
        "completed": { "type": "boolean" }
      },
      "required": ["id", "userId", "type", "date", "time"]
    },
    "HealthAlert": {
      "title": "Health Alert",
      "description": "Records of symptoms checked and alerts triggered.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "symptoms": { "type": "array", "items": { "type": "string" } },
        "severity": { "type": "string" }
      },
      "required": ["id", "userId", "timestamp", "symptoms"]
    },
    "HealthRecord": {
      "title": "Health Record",
      "description": "Medical history, lab results, and vaccination dates.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["vaccination", "lab", "photo"] },
        "label": { "type": "string" },
        "date": { "type": "string" },
        "value": { "type": "string" },
        "status": { "type": "string" },
        "fileUrl": { "type": "string" },
        "fileType": { "type": "string" }
      },
      "required": ["id", "userId", "type", "label"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "Profile",
      "description": "User profile data."
    },
    "/users/{userId}/kick_sessions/{sessionId}": {
      "schema": "KickSession",
      "description": "Historical kick count sessions for the user."
    },
    "/users/{userId}/nutrition/{date}": {
      "schema": "NutritionLog",
      "description": "Daily nutrition checklist for the user."
    },
    "/users/{userId}/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Scheduled appointments for the user."
    },
    "/users/{userId}/health_alerts/{alertId}": {
      "schema": "HealthAlert",
      "description": "Symptom check history."
    },
    "/users/{userId}/health_records/{recordId}": {
      "schema": "HealthRecord",
      "description": "Medical folders, vaccinations, and lab results."
    }
  }
}
